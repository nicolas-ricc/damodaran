# DuckDB file path
BOT_DB_PATH=./bot.duckdb

# SEC EDGAR requires a User-Agent identifying you (per their fair-use policy)
# Format: "Name email@example.com"
BOT_SEC_USER_AGENT=Nicolas Riccomini nicolas.riccomini@gmail.com

# Financial Modeling Prep API key (required — global fundamentals + EOD prices)
BOT_FMP_API_KEY=your-fmp-api-key

# Reports output directory
BOT_REPORTS_DIR=./reports

# Interactive Brokers TWS API (M5) — read-only portfolio sync.
# Requires TWS / IB Gateway running and logged in (see README).
BOT_IBKR_HOST=127.0.0.1
# 7496 = live TWS (default), 7497 = paper TWS, 4001/4002 = IB Gateway live/paper
BOT_IBKR_PORT=7496
BOT_IBKR_CLIENT_ID=1

# Logging
BOT_LOG_LEVEL=INFO
